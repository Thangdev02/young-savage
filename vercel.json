{
  "version": 2,
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/[...route].js": {
      "runtime": "nodejs20.x",
      "includeFiles": "database.json"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...route].js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}